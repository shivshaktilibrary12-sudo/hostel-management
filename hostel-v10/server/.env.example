# ─────────────────────────────────────────────────────────────
#  Hostel Management System — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/hostel_management
# Atlas:   mongodb+srv://username:password@cluster.mongodb.net/hostel_management
MONGODB_URI=mongodb://localhost:27017/hostel_management

# Server port (Render/Railway uses PORT env automatically)
PORT=5000

# JWT Secret — MUST be a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Environment
NODE_ENV=production

# Google Sheets (optional — only for backup export)
GOOGLE_SHEET_ID=your_sheet_id_here

# Allowed origins (comma-separated) — set to your deployed frontend URL
# Leave empty to allow all origins (fine for local use)
ALLOWED_ORIGINS=https://your-app.onrender.com
